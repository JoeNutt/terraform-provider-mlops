{
	"name": "MLOps Provider Dev",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
	},
	"remoteUser": "vscode",
	"customizations": {
		"vscode": {
			"extensions": [
				"golang.go",
				"hashicorp.terraform"
			]
		},
		"jetbrains": {
			"goland": {
				"plugins": [
					"org.intellij.plugins.hcl"
				]
			}
		}
	}
}
